--// INPUT
local uis = game:GetService("UserInputService")

-- toggle desync
uis.InputBegan:Connect(function(a, t)
    if not t and a.KeyCode == getgenv().KeyBind then
        getgenv().Desync = not getgenv().Desync

        if getgenv().Desync then
            status.Text = "STATUS: ON"
            status.TextColor3 = Color3.new(0,1,0)
        else
            status.Text = "STATUS: OFF"
            status.TextColor3 = Color3.new(1,0,0)
        end
    end
end)

--// SECRET CODE SYSTEM (FIXED 331010)
local sequence = {"Three","Three","One","Zero","One","Zero"}
local inputBuffer = {}
local lastInputTime = 0
local maxDelay = 5

uis.InputBegan:Connect(function(input, gp)
    if gp then return end

    local key = input.KeyCode.Name
    if key ~= "One" and key ~= "Zero" and key ~= "Three" then return end

    local currentTime = tick()

    -- reset if too slow
    if currentTime - lastInputTime > maxDelay then
        inputBuffer = {}
    end

    lastInputTime = currentTime
    table.insert(inputBuffer, key)

    -- step-by-step check
    for i = 1, #inputBuffer do
        if inputBuffer[i] ~= sequence[i] then
            inputBuffer = {} -- reset if wrong
            return
        end
    end

    -- full correct sequence
    if #inputBuffer == #sequence then
        frame.Visible = not frame.Visible
        inputBuffer = {}
    end
end)

--// DIRECTION
getgenv().Direction = Vector3.new(0,1,0)

--// MAIN LOOP
game:GetService("RunService").Heartbeat:Connect(function()
    if getgenv().Desync then
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local hrp = char.HumanoidRootPart
            local old = hrp.Velocity

            hrp.Velocity = getgenv().Direction * (2^17)

            game:GetService("RunService").RenderStepped:Wait()

            hrp.Velocity = old
        end
    end
end)
