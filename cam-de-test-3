local function stopCamera()
    isRunning = false
    isPaused = false
    currentMode = ""
    transitionMode = false
    
    if cameraLockConnection then
        cameraLockConnection:Disconnect()
        cameraLockConnection = nil
    end
    
    RunService:UnbindFromRenderStep("CinematicCameraPro")
    
    Camera.CameraType = Enum.CameraType.Custom
    Camera.FieldOfView = 70
end

local function getTargetVehicle()
    if LocalPlayer.Character then
        local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
        if humanoid and humanoid.SeatPart then
            return humanoid.SeatPart
        end
        return LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    end
    return nil
end

local function updateCamera(dt)
    if not isRunning then return end
    
    local driveSeat = getTargetVehicle()
    if not driveSeat or not driveSeat.Parent then 
        stopCamera()
        return 
    end
    
    if not isPaused then
        angle = angle + (dt * 0.4)
        if not loopEnabled and angle >= (math.pi * 2) then
            stopCamera()
            return
        end
    end
    
    local targetPos = driveSeat.Position
    local calculatedFrame = Camera.CFrame
    
    if currentMode == "Forza Orbit" then
        local offset = Vector3.new(math.sin(angle) * 14, 3.5, math.cos(angle) * 14)
        calculatedFrame = CFrame.new(targetPos + offset, targetPos + Vector3.new(0, 0.8, 0))
        
    elseif currentMode == "Standard Tour" then
        local offset = Vector3.new(math.sin(angle * 0.6) * 18, 5 + math.sin(angle) * 1.5, math.cos(angle * 0.6) * 18)
        calculatedFrame = CFrame.new(targetPos + offset, targetPos)
        
    elseif currentMode == "Side Swing" then
        local offset = Vector3.new(16, 2.5, math.sin(angle * 1.2) * 7)
        calculatedFrame = CFrame.new(targetPos + offset, targetPos)
        
    elseif currentMode == "Rear Follow" then
        local backward = -driveSeat.CFrame.LookVector
        local offset = (backward * 15) + Vector3.new(0, 3.5, 0) + (driveSeat.CFrame.RightVector * math.sin(angle) * 1.5)
        calculatedFrame = CFrame.new(targetPos + offset, targetPos + (driveSeat.CFrame.LookVector * 8))
        
    elseif currentMode == "Top View Circle" then
        local offset = Vector3.new(math.sin(angle) * 9, 20, math.cos(angle) * 9)
        calculatedFrame = CFrame.new(targetPos + offset, targetPos)
    end
    
    targetCFrame = calculatedFrame
    
    local currentSpeed = lerpSpeed
    if transitionMode then
        transitionTime = transitionTime + dt
        currentSpeed = lerpSpeed * math.clamp(transitionTime * 2, 0.5, 1)
        if transitionTime >= 1.5 then
            transitionMode = false
        end
    end
    
    Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, currentSpeed * (dt * 60))
end

local function startTour(mode)
    local driveSeat = getTargetVehicle()
    if not driveSeat then 
        warn("[SYSTEM ERROR]: You must sit in the car's driver seat first!")
        return 
    end
    
    if isRunning then
        currentMode = mode
        angle = 0
        transitionMode = true
        transitionTime = 0
        return
    end

    if cameraLockConnection then cameraLockConnection:Disconnect() end
    Camera.CameraType = Enum.CameraType.Scriptable
    
    cameraLockConnection = Camera:GetPropertyChangedSignal("CameraType"):Connect(function()
        if isRunning and Camera.CameraType ~= Enum.CameraType.Scriptable then
            Camera.CameraType = Enum.CameraType.Scriptable
        end
    end)

    isRunning = true
    isPaused = false
    currentMode = mode
    angle = 0
    targetCFrame = Camera.CFrame
    transitionMode = false

    -- Forced RenderStep bind
    RunService:BindToRenderStep("CinematicCameraPro", Enum.RenderPriority.Camera.Value + 10, updateCamera)
end

