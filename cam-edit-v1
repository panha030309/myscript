local function stopCamera()
    isRunning = false
    currentMode = ""
    if currentConnection then
        currentConnection:Disconnect()
        currentConnection = nil
    end
    Camera.CameraType = Enum.CameraType.Custom
end

local function getTargetVehicle()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        if LocalPlayer.Character:FindFirstChild("Humanoid") and LocalPlayer.Character.Humanoid.SeatPart then
            return LocalPlayer.Character.Humanoid.SeatPart.Parent
        end
    end
    return nil
end

local function startTour(mode)
    stopCamera()
    local vehicle = getTargetVehicle()
    if not vehicle or not vehicle:FindFirstChild("DriveSeat") then 
        warn("[SYSTEM ERROR]: No active vehicle detected. Sit in the vehicle driver seat.")
        return 
    end
    
    local targetPart = vehicle.DriveSeat
    Camera.CameraType = Enum.CameraType.Scriptable
    isRunning = true
    currentMode = mode
    angle = 0

    currentConnection = RunService.RenderStepped:Connect(function(dt)
        if not isRunning or not targetPart or not targetPart.Parent then 
            stopCamera()
            return 
        end
        
        angle = angle + (dt * 0.4) -- Smoothed rotational velocity factor
        local targetPos = targetPart.Position
        
        if currentMode == "Forza Orbit" then
            local offset = Vector3.new(math.sin(angle) * 14, 3.5, math.cos(angle) * 14)
            Camera.CFrame = CFrame.new(targetPos + offset, targetPos + Vector3.new(0, 0.8, 0))
            
        elseif currentMode == "Standard Tour" then
            local offset = Vector3.new(math.sin(angle * 0.6) * 18, 5 + math.sin(angle) * 1.5, math.cos(angle * 0.6) * 18)
            Camera.CFrame = CFrame.new(targetPos + offset, targetPos)
            
        elseif currentMode == "Side Swing" then
            local offset = Vector3.new(16, 2.5, math.sin(angle * 1.2) * 7)
            Camera.CFrame = CFrame.new(targetPos + offset, targetPos)
            
        elseif currentMode == "Rear Follow" then
            local backward = -targetPart.CFrame.LookVector
            local offset = (backward * 15) + Vector3.new(0, 3.5, 0) + (targetPart.CFrame.RightVector * math.sin(angle) * 1.5)
            Camera.CFrame = CFrame.new(targetPos + offset, targetPos + (targetPart.CFrame.LookVector * 8))
            
        elseif currentMode == "Top View Circle" then
            local offset = Vector3.new(math.sin(angle) * 9, 20, math.cos(angle) * 9)
            Camera.CFrame = CFrame.new(targetPos + offset, targetPos)
        end
    end)
end

